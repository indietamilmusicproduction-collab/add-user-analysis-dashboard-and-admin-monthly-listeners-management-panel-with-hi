type http_request_result = 
 record {
   body: blob;
   headers: vec http_header;
   status: nat;
 };
type http_header = 
 record {
   name: text;
   value: text;
 };
type _ImmutableObjectStorageRefillResult = 
 record {
   success: opt bool;
   topped_up_amount: opt nat;
 };
type _ImmutableObjectStorageRefillInformation = record {
                                                  proposed_top_up_amount:
                                                   opt nat;};
type _ImmutableObjectStorageCreateCertificateResult = 
 record {
   blob_hash: text;
   method: text;
 };
type WithdrawStatus = 
 variant {
   approved;
   pending;
   rejected;
 };
type WithdrawRequestInput = 
 record {
   amount: float64;
   fullName: text;
   googlePayAccountName: text;
   message: text;
   qrCodeBlob: ExternalBlob;
   qrCodeFilename: text;
   upiId: text;
 };
type WithdrawRequest = 
 record {
   amount: float64;
   fullName: text;
   googlePayAccountName: text;
   id: text;
   message: text;
   qrCodeBlob: ExternalBlob;
   qrCodeFilename: text;
   rejectionReason: text;
   status: WithdrawStatus;
   submitter: principal;
   timestamp: Time;
   upiId: text;
 };
type VideoSubmissionStatus = 
 variant {
   approved;
   live;
   pending;
   rejected;
   waiting;
 };
type VideoSubmissionInput = 
 record {
   artwork: ExternalBlob;
   category: text;
   description: text;
   tags: vec text;
   thumbnail: ExternalBlob;
   title: text;
   videoFile: ExternalBlob;
 };
type VideoSubmission = 
 record {
   artwork: ExternalBlob;
   category: text;
   description: text;
   id: text;
   liveUrl: opt text;
   status: VideoSubmissionStatus;
   submittedAt: Time;
   tags: vec text;
   thumbnail: ExternalBlob;
   title: text;
   updatedAt: Time;
   userId: principal;
   videoFile: ExternalBlob;
 };
type VerificationStatus = 
 variant {
   approved;
   pending;
   rejected;
   waiting;
 };
type VerificationRequest = 
 record {
   expiryExtensionDays: nat;
   id: text;
   status: VerificationStatus;
   timestamp: Time;
   user: principal;
   verificationApprovedTimestamp: opt Time;
 };
type UserRole = 
 variant {
   admin;
   guest;
   user;
 };
type UserProfile = 
 record {
   artistId: text;
   category: UserCategory;
   name: text;
 };
type UserCategory = 
 variant {
   generalArtist;
   generalLabel;
   proArtist;
   proLabel;
   ultraArtist;
 };
type UserApprovalInfo = 
 record {
   "principal": principal;
   status: ApprovalStatus;
 };
type TransformationOutput = 
 record {
   body: blob;
   headers: vec http_header;
   status: nat;
 };
type TransformationInput = 
 record {
   context: blob;
   response: http_request_result;
 };
type TrackMetadata = 
 record {
   artist: text;
   audioFile: ExternalBlob;
   audioFilename: text;
   composer: text;
   featuredArtist: text;
   lyricist: text;
   producer: text;
   title: text;
 };
type TopVibingSong = 
 record {
   artistName: text;
   artworkUrl: text;
   genre: text;
   id: nat;
   rank: nat;
   streamingLink: text;
   tagline: opt text;
   title: text;
 };
type Time = int;
type SubscriptionPlan = 
 record {
   benefits: vec text;
   planName: text;
   pricePerYear: nat;
   redirectUrl: text;
 };
type StripeSessionStatus = 
 variant {
   completed: record {
                response: text;
                userPrincipal: opt text;
              };
   failed: record {error: text;};
 };
type StripeConfiguration = 
 record {
   allowedCountries: vec text;
   secretKey: text;
 };
type SongSubmissionInput = 
 record {
   additionalDetails: text;
   albumTracks: opt vec TrackMetadata;
   appleMusicLink: opt text;
   artist: text;
   artworkBlob: ExternalBlob;
   artworkFilename: text;
   audioBlob: ExternalBlob;
   audioFilename: text;
   callerTuneStartSecond: opt float64;
   composer: text;
   contentId: opt bool;
   contentType: opt text;
   customCLine: opt text;
   customPLine: opt text;
   discountCode: opt text;
   featuredArtist: text;
   genre: text;
   language: text;
   licenceFile: opt ExternalBlob;
   licenceFilename: opt text;
   lyricist: text;
   musicVideoLink: opt text;
   premiumLabel: opt text;
   producer: text;
   releaseDate: Time;
   releaseType: text;
   spotifyLink: opt text;
   sunoAgreementFile: opt ExternalBlob;
   sunoAgreementFilename: opt text;
   sunoTrackLink: opt text;
   title: text;
 };
type SongSubmissionEditInput = 
 record {
   additionalDetails: text;
   albumTracks: opt vec TrackMetadata;
   appleMusicLink: opt text;
   artist: text;
   artworkBlob: ExternalBlob;
   artworkFilename: text;
   audioFile: ExternalBlob;
   audioFilename: text;
   composer: text;
   discountCode: opt text;
   featuredArtist: text;
   genre: text;
   language: text;
   lyricist: text;
   musicVideoLink: opt text;
   producer: text;
   releaseDate: Time;
   releaseType: text;
   songSubmissionId: text;
   spotifyLink: opt text;
   title: text;
 };
type SongSubmissionAdmin = 
 record {
   acrResult: opt ACRResult;
   additionalDetails: text;
   adminComment: text;
   adminLiveLink: opt text;
   adminRemarks: text;
   albumTracks: opt vec TrackMetadata;
   appleMusicLink: opt text;
   artist: text;
   artwork: ExternalBlob;
   artworkFilename: text;
   audioFile: ExternalBlob;
   audioFilename: text;
   callerTuneStartSecond: opt float64;
   composer: text;
   contentId: opt bool;
   contentType: opt text;
   customCLine: opt text;
   customPLine: opt text;
   discountCode: opt text;
   featuredArtist: text;
   genre: text;
   id: text;
   isManuallyRejected: bool;
   language: text;
   licenceFile: opt ExternalBlob;
   licenceFilename: opt text;
   liveStreamLink: opt text;
   lyricist: text;
   monthlyListeners: opt float64;
   musicVideoLink: opt text;
   preSaveLink: opt text;
   premiumLabel: opt text;
   producer: text;
   publicLink: opt text;
   releaseDate: Time;
   releaseType: text;
   revenue: opt float64;
   spotifyLink: opt text;
   status: SongStatus;
   submitter: principal;
   sunoAgreementFile: opt ExternalBlob;
   sunoAgreementFilename: opt text;
   sunoTrackLink: opt text;
   timestamp: Time;
